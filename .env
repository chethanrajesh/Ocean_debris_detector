# Environment variables for ocean_plastic project

# API Keys (replace with your actual keys)
# SATELLITE_API_KEY=your_api_key_here

# Database Configuration
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ocean_plastic
# DB_USER=user
# DB_PASSWORD=password

# Model Configuration
# MODEL_NAME=yolov8
# GPU_ENABLED=true

# Paths
# DATA_PATH=./data
# MODEL_PATH=./models

# Logging
# LOG_LEVEL=INFO

# Development
# DEBUG=false
