# ── NASA Earthdata ────────────────────────────────────────────────────────────
EARTHDATA_USERNAME=your_earthdata_username
EARTHDATA_PASSWORD=your_earthdata_password

# ── CMEMS (Copernicus Marine) ─────────────────────────────────────────────────
CMEMS_USERNAME=your_cmems_username
CMEMS_PASSWORD=your_cmems_password

# ── Google Earth Engine ───────────────────────────────────────────────────────
GEE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GEE_SERVICE_ACCOUNT_KEY=path/to/your-gee-key.json
